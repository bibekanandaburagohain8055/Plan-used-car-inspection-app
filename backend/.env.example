PORT=5050
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
OPENAI_TRANSCRIBE_MODEL=gpt-4o-mini-transcribe

# Vehicle lookup provider
# Options: generic | apyflux
INDIA_VEHICLE_PROVIDER=apyflux

# Apyflux RC Full API config
APYFLUX_URL=https://gateway.apyflux.com/rc-full
APYFLUX_APP_ID=
APYFLUX_CLIENT_ID=
APYFLUX_API_KEY=

# Generic vehicle API fallback config
INDIA_VEHICLE_API_URL=
INDIA_VEHICLE_API_METHOD=POST
INDIA_VEHICLE_API_BODY_FIELD=registrationNumber
INDIA_VEHICLE_API_AUTH_HEADER=Authorization
INDIA_VEHICLE_API_AUTH_TOKEN=
INDIA_VEHICLE_API_KEY_HEADER=x-api-key
INDIA_VEHICLE_API_KEY=
INDIA_VEHICLE_API_HEADERS_JSON=
