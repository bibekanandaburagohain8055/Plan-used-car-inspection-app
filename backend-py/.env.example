# Server
PORT=5050

# Claude (required — photo analysis, audio analysis, report generation)
ANTHROPIC_API_KEY=your-anthropic-api-key
CLAUDE_MODEL=claude-sonnet-4-6

# OpenAI (required only for audio transcription via Whisper)
OPENAI_API_KEY=your-openai-api-key
OPENAI_TRANSCRIBE_MODEL=gpt-4o-mini-transcribe

# Cashfree RC API (vehicle lookup)
VEHICLE_RC_URL=https://sandbox.cashfree.com/verification/vehicle-rc
VEHICLE_RC_CLIENT_ID=your-cashfree-client-id
VEHICLE_RC_CLIENT_SECRET=your-cashfree-client-secret
